<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0a0e17">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp">
        
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🎬 Megan"
            android:textSize="18sp"
            android:textColor="#e50914"
            android:textStyle="bold"/>
        
        <!-- Search Bar -->
        <LinearLayout
            android:id="@+id/searchContainer"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:layout_marginHorizontal="12dp"
            android:background="@drawable/search_bg"
            android:gravity="center_vertical"
            android:paddingHorizontal="12dp">
            
            <EditText
                android:id="@+id/searchInput"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@null"
                android:hint="Search..."
                android:textColorHint="#666666"
                android:textColor="#ffffff"
                android:textSize="13sp"
                android:imeOptions="actionSearch"
                android:inputType="text"/>
        </LinearLayout>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Hero Banner -->
            <androidx.viewpager2.widget.ViewPager2
                android:id="@+id/heroViewPager"
                android:layout_width="match_parent"
                android:layout_height="220dp"/>

            <LinearLayout
                android:id="@+id/bannerInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="12dp"
                android:paddingTop="6dp"
                android:gravity="center_vertical">
                
                <TextView
                    android:id="@+id/bannerTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="#ffffff"
                    android:textSize="16sp"
                    android:textStyle="bold"/>
                    
                <TextView
                    android:id="@+id/bannerType"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/type_badge"
                    android:textColor="#00d4ff"
                    android:textSize="10sp"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="2dp"/>
            </LinearLayout>

            <!-- Dots -->
            <LinearLayout
                android:id="@+id/dotsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:padding="8dp"/>

            <!-- Sections -->
            <include layout="@layout/item_section" android:id="@+id/trendingRow"/>
            <include layout="@layout/item_section" android:id="@+id/popularMoviesRow"/>
            <include layout="@layout/item_section" android:id="@+id/popularSeriesRow"/>
            <include layout="@layout/item_section" android:id="@+id/actionRow"/>
            <include layout="@layout/item_section" android:id="@+id/horrorRow"/>
            <include layout="@layout/item_section" android:id="@+id/romanceRow"/>
            <include layout="@layout/item_section" android:id="@+id/adventureRow"/>
            <include layout="@layout/item_section" android:id="@+id/animeRow"/>
            <include layout="@layout/item_section" android:id="@+id/kdramaRow"/>
            <include layout="@layout/item_section" android:id="@+id/upcomingRow"/>

            <!-- Footer -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="24dp">
                
                <TextView
                    android:id="@+id/footerLink"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Open movies.megan.qzz.io"
                    android:textColor="#00d4ff"
                    android:textSize="13sp"
                    android:padding="8dp"/>
                    
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Made with ❤️ by Tracker Wanga"
                    android:textColor="#666666"
                    android:textSize="11sp"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
